# Force LF line endings on all source files so Windows checkouts don't
# create spurious "modified" changes that block git pull / alvasta upgrade.
* text=auto eol=lf

# Treat these as text + force LF
*.js   text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.svg  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files (no text conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
